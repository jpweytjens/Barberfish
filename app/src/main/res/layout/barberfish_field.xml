<?xml version="1.0" encoding="utf-8"?>
<!--
    Field layout: RIGHT-aligned.
    Mirrors native data_element_single.xml ConstraintLayout in RemoteViews-safe views.
    field_header (wrap_content, minHeight=22dp) maps to native DataHeaderView; can
    grow to 2 lines like native. baseline_box fills from field_header's bottom to
    the cell bottom — a nested RelativeLayout whose layout_centerVertical mimics
    ConstraintLayout's bias-0.5 centering between (headerBottom, cellBottom).
    baseline_ref centers within baseline_box at valueFontSizeBase; field_value
    alignBaseline locks to that line. clipChildren=false on every layer lets the
    value's wrap_content bounding box overflow upward into the header zone — the
    digit cap-line for monospace sits below the single-line label glyphs, so the
    overlap is invisible (the same trade native makes via ConstraintLayout's
    permissive overflow centering).
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/field_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <!-- Stream state (Searching/NotAvailable/Idle): GONE by default. -->
    <TextView
        android:id="@+id/stream_state_tv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical|end"
        android:fontFamily="ibm-plex-sans-condensed"
        android:fontWeight="500"
        android:textColor="@android:color/white"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:lineSpacingMultiplier="0.7"
        android:visibility="gone" />

    <!-- Header row: at top. Mirrors native DataHeaderView, which renders at ~48 px
         (= 26dp) on most layouts because dataIconStyle's icon (20dp) + 3dp top/bottom
         margins from layout_data_header.xml dominate the dataHeader style's 22dp
         minHeight floor. 26dp here matches that effective height. -->
    <LinearLayout
        android:id="@+id/field_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:minHeight="22dp"
        android:clipToPadding="false"
        android:paddingStart="1dp"
        android:paddingEnd="1dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/field_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/field_icon_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/field_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:lines="2"
            android:gravity="center_vertical|end"
            android:ellipsize="end"
            android:textAllCaps="true"
            android:fontFamily="ibm-plex-sans-condensed"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="0.7"
            android:breakStrategy="simple" />

    </LinearLayout>

    <!-- Centering box: fills from field_header's bottom to the cell bottom.
         Anchored to field_header (not a fixed-22dp shim) so it shrinks when the
         label wraps to 2 lines, preventing the second line from drawing into the
         centering region. layout_centerVertical inside this box mirrors native
         ConstraintLayout's default bias-0.5 between (headerBottom, cellBottom). -->
    <RelativeLayout
        android:id="@+id/baseline_box"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/field_header"
        android:layout_alignParentBottom="true"
        android:clipChildren="false">

        <TextView
            android:id="@+id/baseline_ref"
            android:layout_width="1px"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:fontFamily="monospace"
            android:includeFontPadding="true"
            android:text="REF"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/field_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignBaseline="@id/baseline_ref"
            android:baselineAligned="false"
            android:gravity="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="relative"
            android:letterSpacing="-0.04" />

    </RelativeLayout>

</RelativeLayout>
