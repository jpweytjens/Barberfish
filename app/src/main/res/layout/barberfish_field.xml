<?xml version="1.0" encoding="utf-8"?>
<!--
    Field layout: RIGHT-aligned.
    Mirrors native data_element_single.xml ConstraintLayout in RemoteViews-safe views.
    header_spacer (22dp) matches native DataHeaderView minHeight. baseline_box fills
    below it to the cell bottom — a nested RelativeLayout that gives
    layout_centerVertical a correctly-measured container. baseline_ref centers within
    baseline_box at valueFontSizeBase; field_value.alignBaseline locks to that line.
    Decoupled from field_header so 2-line labels don't push the value down.
    clipChildren=false allows large text to overflow into the header zone.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/field_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <!-- Stream state (Searching/NotAvailable/Idle): GONE by default. -->
    <TextView
        android:id="@+id/stream_state_tv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical|end"
        android:fontFamily="ibm-plex-sans-condensed"
        android:fontWeight="500"
        android:textColor="@android:color/white"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:lineSpacingMultiplier="0.7"
        android:visibility="gone" />

    <!-- Invisible spacer: matches native DataHeaderView minHeight (22dp).
         Decoupled from field_header so 2-line labels don't push the value down. -->
    <TextView
        android:id="@+id/header_spacer"
        android:layout_width="1px"
        android:layout_height="22dp"
        android:layout_alignParentTop="true"
        android:visibility="invisible" />

    <!-- Header row: at top. Mirrors native DataHeaderView. -->
    <LinearLayout
        android:id="@+id/field_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:minHeight="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/field_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/field_icon_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/field_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:lines="1"
            android:gravity="center_vertical|end"
            android:ellipsize="end"
            android:textAllCaps="true"
            android:fontFamily="ibm-plex-sans-condensed"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="0.7"
            android:breakStrategy="simple" />

    </LinearLayout>

    <!-- Centering box: fills below-spacer to cell bottom. layout_centerVertical
         inside this box centers baseline_ref in the correct measured bounds. -->
    <RelativeLayout
        android:id="@+id/baseline_box"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_spacer"
        android:layout_alignParentBottom="true"
        android:clipChildren="false">

        <TextView
            android:id="@+id/baseline_ref"
            android:layout_width="1px"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:fontFamily="monospace"
            android:includeFontPadding="true"
            android:text="REF"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/field_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignBaseline="@id/baseline_ref"
            android:gravity="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:letterSpacing="-0.04" />

    </RelativeLayout>

</RelativeLayout>
