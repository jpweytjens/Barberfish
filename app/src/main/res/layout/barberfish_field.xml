<?xml version="1.0" encoding="utf-8"?>
<!--
    Field layout: RIGHT-aligned.
    RelativeLayout root: baseline_ref is an invisible anchor at the bottom at the native
    font size. field_value aligns its baseline to baseline_ref, giving consistent baseline
    positioning across font sizes without translationY. field_header overlays at top.
    RemoteViews-safe: only RelativeLayout, LinearLayout, ImageView, TextView are used.
    Horizontal padding and all text/icon properties are set programmatically.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/field_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <!-- Stream state (Searching/NotAvailable/Idle): ibm-plex-sans-condensed, white. GONE by default. -->
    <TextView
        android:id="@+id/stream_state_tv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical|end"
        android:fontFamily="ibm-plex-sans-condensed"
        android:fontWeight="500"
        android:textColor="@android:color/white"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:lineSpacingMultiplier="0.6"
        android:visibility="gone" />

    <!-- Invisible baseline anchor: native font size, at parent bottom.
         The value aligns its baseline to this view's baseline.
         Set font size programmatically to control baseline distance from bottom. -->
    <TextView
        android:id="@+id/baseline_ref"
        android:layout_width="1px"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:gravity="bottom"
        android:fontFamily="monospace"
        android:includeFontPadding="false"
        android:text=" "
        android:visibility="invisible" />

    <!-- Value: baseline aligned to baseline_ref. Horizontal gravity baked in (end). -->
    <TextView
        android:id="@+id/field_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@id/baseline_ref"
        android:gravity="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:letterSpacing="-0.04" />

    <!-- Header row: at top. Mirrors native DataHeaderView. -->
    <LinearLayout
        android:id="@+id/field_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:minHeight="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/field_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/field_icon_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/field_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:lines="2"
            android:gravity="center_vertical|end"
            android:ellipsize="end"
            android:textAllCaps="true"
            android:fontFamily="ibm-plex-sans-condensed"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="0.6"
            android:breakStrategy="simple" />

    </LinearLayout>

</RelativeLayout>
