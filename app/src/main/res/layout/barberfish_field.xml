<?xml version="1.0" encoding="utf-8"?>
<!--
    Field layout: RIGHT-aligned.
    Mirrors native data_element_single.xml ConstraintLayout in RemoteViews-safe views.
    header_ref (1-line, invisible) is a hidden 1-line probe styled like the native
    dataHeaderTextStyle; baseline_box anchors to its bottom. The visible field_header
    keeps layout_alignParentTop and overlaps header_ref; when its label wraps to 2
    lines, the second line overflows downward into baseline_box (clipChildren=false
    on field_root permits it). baseline_ref centers within baseline_box at
    valueFontSizeBase via layout_centerVertical; field_value alignBaseline locks
    to that line — value position stays constant across font shrinks AND across
    visible header line counts.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/field_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <!-- Stream state (Searching/NotAvailable/Idle): GONE by default. -->
    <TextView
        android:id="@+id/stream_state_tv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical|end"
        android:fontFamily="ibm-plex-sans-condensed"
        android:fontWeight="500"
        android:textColor="@android:color/white"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:lineSpacingMultiplier="0.7"
        android:visibility="gone" />

    <!-- Hidden 1-line header probe. Native dataHeaderTextStyle mirror. Its bottom
         anchors baseline_box, giving the value a stable centering region whose
         top is independent of how many lines the visible field_header wraps to.
         Text size set programmatically in BarberfishView.kt to match field_label.
         The "M" glyph is the tallest cap so the measured band height is the
         worst-case 1-line header height for the chosen font size. -->
    <TextView
        android:id="@+id/header_ref"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginStart="1dp"
        android:lines="1"
        android:textAllCaps="true"
        android:fontFamily="ibm-plex-sans-condensed"
        android:includeFontPadding="false"
        android:lineSpacingMultiplier="0.7"
        android:text="M"
        android:visibility="invisible" />

    <!-- Visible header row. Mirrors native DataHeaderView. Overlaps header_ref
         at parent top; field_label's lines=2 may wrap downward and overflow
         baseline_box (clipChildren=false on field_root absorbs it). -->
    <LinearLayout
        android:id="@+id/field_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:minHeight="22dp"
        android:clipToPadding="false"
        android:paddingStart="1dp"
        android:paddingEnd="1dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/field_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/field_icon_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/field_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:maxLines="2"
            android:gravity="center_vertical|end"
            android:ellipsize="end"
            android:textAllCaps="true"
            android:fontFamily="ibm-plex-sans-condensed"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="0.7"
            android:breakStrategy="simple" />

    </LinearLayout>

    <!-- Centering box: fills from header_ref's bottom to the cell bottom.
         Anchored to the hidden 1-line header probe so the centering region's
         top is constant across visible-header line counts. The visible
         field_header may wrap to 2 lines and overflow into this box;
         clipChildren=false on field_root absorbs it. layout_centerVertical
         inside this box mirrors native ConstraintLayout's default bias-0.5
         between (headerBottom, cellBottom). -->
    <RelativeLayout
        android:id="@+id/baseline_box"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_ref"
        android:layout_alignParentBottom="true"
        android:clipChildren="false">

        <!-- Mirrors native singleNumericDataStyle (relative, includeFontPadding=false,
             letterSpacing=-0.04) so this 1px-wide invisible reference TextView
             measures exactly like a one-char field_value. layout_centerVertical
             inside baseline_box reproduces native's ConstraintLayout bias-0.5
             centering between (headerBottom, cellBottom). field_value's
             alignBaseline locks to this baseline across fontSizeForCell shrinks. -->
        <TextView
            android:id="@+id/baseline_ref"
            android:layout_width="1px"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:fontFamily="relative"
            android:includeFontPadding="false"
            android:letterSpacing="-0.04"
            android:text="0"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/field_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignBaseline="@id/baseline_ref"
            android:baselineAligned="false"
            android:gravity="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="relative"
            android:letterSpacing="-0.04" />

    </RelativeLayout>

</RelativeLayout>
