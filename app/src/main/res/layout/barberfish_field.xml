<?xml version="1.0" encoding="utf-8"?>
<!--
    Field layout matching native data_element_single.xml centering behaviour.
    A RelativeLayout fills the space below the header (layout_weight="1"), and
    field_value uses layout_centerVertical="true" to center itself (wrap_content) within it.
    This mirrors ConstraintLayout (top_toBottomOf=header + bottom_toBottomOf=parent + wrap_content).
    RemoteViews-safe: only LinearLayout, RelativeLayout, ImageView, TextView are used.
    Horizontal padding and all text/icon properties are set programmatically.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/field_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header row: optional icon + label. Mirrors native DataHeaderView. -->
    <LinearLayout
        android:id="@+id/field_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/field_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/field_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:lines="2"
            android:gravity="center_vertical"
            android:ellipsize="end"
            android:textAllCaps="true"
            android:fontFamily="ibm-plex-sans-condensed"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="0.7"
            android:breakStrategy="simple" />

    </LinearLayout>

    <!-- Value container: fills remaining space, centers field_value vertically.
         RelativeLayout + layout_centerVertical mirrors ConstraintLayout wrap_content centering. -->
    <RelativeLayout
        android:id="@+id/field_value_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        >

        <TextView
            android:id="@+id/field_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:fontFamily="relative"
            android:letterSpacing="-0.04" />

    </RelativeLayout>

</LinearLayout>
