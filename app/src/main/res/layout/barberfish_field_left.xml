<?xml version="1.0" encoding="utf-8"?>
<!--
    Field layout: LEFT-aligned.
    Same structure as barberfish_field.xml, but icon order is flipped: label first,
    icon(s) trailing (icon anchors to alignment side).
    See barberfish_field.xml for documentation.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/field_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <TextView
        android:id="@+id/stream_state_tv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical|start"
        android:fontFamily="ibm-plex-sans-condensed"
        android:fontWeight="500"
        android:textColor="@android:color/white"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:lineSpacingMultiplier="0.7"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/field_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:minHeight="22dp"
        android:clipToPadding="false"
        android:paddingStart="1dp"
        android:paddingEnd="1dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/field_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dp"
            android:lines="2"
            android:gravity="center_vertical|start"
            android:ellipsize="end"
            android:textAllCaps="true"
            android:fontFamily="ibm-plex-sans-condensed"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="0.7"
            android:breakStrategy="simple" />

        <ImageView
            android:id="@+id/field_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/field_icon_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone" />

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/baseline_box"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/field_header"
        android:layout_alignParentBottom="true"
        android:clipChildren="false">

        <TextView
            android:id="@+id/baseline_ref"
            android:layout_width="1px"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:fontFamily="monospace"
            android:includeFontPadding="true"
            android:text="REF"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/field_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignBaseline="@id/baseline_ref"
            android:baselineAligned="false"
            android:gravity="start"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="relative"
            android:letterSpacing="-0.04" />

    </RelativeLayout>

</RelativeLayout>